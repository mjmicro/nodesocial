# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# Supabase
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""

# Redis (Upstash)
UPSTASH_REDIS_URL="https://[endpoint].upstash.io"   # REST client (@upstash/redis) — for cache reads
UPSTASH_REDIS_TOKEN=""
REDIS_URL="rediss://default:[token]@[endpoint].upstash.io:6380"  # ioredis — for BullMQ queues

# Storage (Cloudflare R2)
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Search (Typesense)
TYPESENSE_HOST=""
TYPESENSE_API_KEY=""

# Auth
JWT_SECRET=""

# Internal services
REPUTATION_SERVICE_URL="http://localhost:8000"
